<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
  <Description>Default proxy endpoint for retail agent API.</Description>
  <HTTPProxyConnection>
    <BasePath>/retail-agent/v1</BasePath>
    <VirtualHost>default</VirtualHost>
  </HTTPProxyConnection>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Name>Verify-API-Key</Name>
      </Step>
      <Step>
        <Name>Spike-Arrest</Name>
      </Step>
    </Request>
    <Response>
      <Step>
        <Name>AssignMessage-CORS</Name>
      </Step>
    </Response>
  </PreFlow>
  <RouteRule name="default">
    <TargetEndpoint>default</TargetEndpoint>
  </RouteRule>
</ProxyEndpoint>
